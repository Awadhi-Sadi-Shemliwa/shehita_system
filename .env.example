# Production secrets for docker-compose.prod.yml
# --------------------------------------------------
# Copy this file to ".env" on the VPS and replace every value below.
# NEVER commit the real .env file to git.
#
# Generate strong random values, e.g. on the VPS:
#   openssl rand -base64 24

# MySQL root password (also used by the app to connect).
MYSQL_ROOT_PASSWORD=replace-with-a-long-random-string

# Application database name.
DB_NAME=shehita_business

# Initial administrator account created on first run.
# Log in with these, then change the password from inside the app.
ADMIN_DEFAULT_EMAIL=admin@shehita.co.tz
ADMIN_DEFAULT_PASSWORD=replace-with-a-strong-password
